{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development"
		},
		"preview": {
			"extends": "production",
			"distribution": "internal",
			"channel": "preview",
			"android": {
				"buildType": "apk"
			}
		},
		"production": {
			"autoIncrement": true,
			"channel": "production"
		}
	},
	"submit": {
		"production": {}
	}
}

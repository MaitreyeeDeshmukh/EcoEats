{
	"name": "ecoeats-native",
	"version": "1.0.0",
	"main": "expo-router/entry",
	"scripts": {
		"api": "bun server/index.ts",
		"api:dev": "bun --watch server/index.ts",
		"api:worker:dev": "wrangler dev --port 8787",
		"api:worker:deploy": "wrangler deploy",
		"api:worker:types": "wrangler types",
		"api:worker:check": "wrangler check startup",
		"auth:migrate": "bunx @better-auth/cli@latest migrate --config server/auth.ts",
		"eas:build:android": "bunx eas-cli@latest build -p android --profile production",
		"eas:build:ios": "bunx eas-cli@latest build -p ios --profile production",
		"eas:build:local:android": "bunx eas-cli@latest build -p android --profile preview --local",
		"eas:build:local:ios": "bunx eas-cli@latest build -p ios --profile preview --local",
		"eas:submit:android": "bunx eas-cli@latest submit -p android --profile production",
		"eas:submit:ios": "bunx eas-cli@latest submit -p ios --profile production",
		"test": "vitest run --exclude \"src/**\" server/",
		"test:watch": "vitest --exclude \"src/**\" server/",
		"test:coverage": "vitest run --coverage --exclude \"src/**\" server/",
		"test:frontend": "jest --passWithNoTests",
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"prepare": "husky"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.13",
		"@hono/zod-validator": "^0.7.6",
		"@opentelemetry/api": "^1.9.0",
		"better-auth": "^1.6.1",
		"expo": "~55.0.13",
		"expo-constants": "~55.0.13",
		"expo-linking": "~55.0.12",
		"expo-router": "~55.0.11",
		"expo-secure-store": "~55.0.13",
		"expo-status-bar": "~55.0.5",
		"hono": "^4.12.12",
		"hono-rate-limiter": "^0.5.3",
		"nativewind": "^4.2.3",
		"pg": "^8.20.0",
		"phosphor-react-native": "^3.0.4",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.4",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "15.15.3",
		"react-native-toast-message": "^2.3.3",
		"react-native-web": "^0.21.2",
		"react-native-worklets": "0.7.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/jest-native": "^5.4.3",
		"@testing-library/react-native": "^13.3.3",
		"@types/jest": "^30.0.0",
		"@types/react": "~19.2.14",
		"@vitest/coverage-v8": "^4.1.4",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"jest-expo": "^55.0.15",
		"knip": "^6.3.1",
		"lint-staged": "^16.4.0",
		"tailwindcss": "^3.4.19",
		"ts-jest": "^29.4.9",
		"typescript": "~5.9.2",
		"vitest": "^4.1.4",
		"wrangler": "^4.81.1"
	},
	"private": true,
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"biome check --write",
			"tsc --noEmit"
		]
	}
}
